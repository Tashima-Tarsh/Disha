# App Configuration
APP_NAME=AI Intelligence Platform
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production

# PostgreSQL
POSTGRES_URL=postgresql://postgres:postgres@postgres:5432/intelligence_db

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=your-neo4j-password

# ChromaDB
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# External APIs
SHODAN_API_KEY=your-shodan-api-key
ETHERSCAN_API_KEY=your-etherscan-api-key
ALCHEMY_API_KEY=your-alchemy-api-key
SPIDERFOOT_API_KEY=your-spiderfoot-api-key

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_TOPIC_EVENTS=intelligence-events
KAFKA_TOPIC_ALERTS=intelligence-alerts

# LLM
LLM_MODEL=gpt-4
LLM_TEMPERATURE=0.1
