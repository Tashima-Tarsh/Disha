{
  "name": "@tashima-tarsh/disha",
  "version": "6.0.0",
  "description": "An elite autonomous AGI platform for cognitive defense, strategic reasoning, and digital intelligence.",
  "license": "UNLICENSED",
  "private": true,
  "type": "module",
  "workspaces": [
    "disha/apps/*",
    "disha/services/*",
    "disha/ai/*"
  ],
  "main": "disha/legacy-root-src/main.tsx",
  "bin": {
    "disha": "disha/legacy-root-src/main.tsx"
  },
  "scripts": {
    "lint": "biome check disha/",
    "lint:fix": "biome check --write disha/",
    "format": "biome format --write disha/",
    "check": "biome check disha/ && tsc --noEmit",
    "dev": "npx esbuild disha/legacy-root-src/main.tsx --bundle --platform=node --format=esm --outfile=dist/cli.mjs --watch",
    "start": "node dist/cli.mjs",
    "test": "echo \"No root tests configured\" && exit 0",
    "build": "npx esbuild disha/legacy-root-src/main.tsx --bundle --platform=node --format=esm --outfile=dist/cli.mjs",
    "build:web": "cd disha/apps/web && npm run build",
    "dev:web": "cd disha/apps/web && npm run dev",
    "dev:mcp": "cd disha/services/mcp && npm run dev"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.89.0",
    "@commander-js/extra-typings": "^14.0.0",
    "@growthbook/growthbook": "^1.6.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.214.0",
    "@opentelemetry/core": "^2.6.1",
    "@opentelemetry/sdk-logs": "^0.214.0",
    "@opentelemetry/sdk-metrics": "^2.6.1",
    "@opentelemetry/sdk-trace-base": "^2.6.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-unicode11": "^0.9.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/addon-webgl": "^0.19.0",
    "@xterm/xterm": "^6.0.0",
    "auto-bind": "^5.0.1",
    "axios": "^1.15.0",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "cli-boxes": "^4.0.1",
    "code-excerpt": "^4.0.0",
    "diff": "^9.0.0",
    "execa": "^9.6.1",
    "figures": "^6.1.0",
    "fuse.js": "^7.3.0",
    "highlight.js": "^11.11.1",
    "ignore": "^7.0.5",
    "lodash-es": "^4.18.1",
    "marked": "^18.0.0",
    "node-pty": "^1.1.0",
    "p-map": "^7.0.4",
    "picomatch": "^4.0.4",
    "proper-lockfile": "^4.1.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-reconciler": "^0.33.0",
    "semver": "^7.7.4",
    "stack-utils": "^2.0.6",
    "strip-ansi": "^7.2.0",
    "supports-hyperlinks": "^4.4.0",
    "tree-kill": "^1.2.2",
    "type-fest": "^5.5.0",
    "undici": "^8.1.0",
    "usehooks-ts": "^3.1.1",
    "wrap-ansi": "^10.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "@types/diff": "^8.0.0",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.8",
    "@types/semver": "^7.7.1",
    "@types/stack-utils": "^2.0.3",
    "@types/ws": "^8.18.1",
    "esbuild": "^0.28.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "bun": ">=1.1.0"
  },
  "packageManager": "bun@1.1.0"
}
