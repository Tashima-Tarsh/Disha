# =============================================================================
# Disha Virtual Cyber Defense System - Environment Configuration
# Copy to .env and adjust values as needed
# =============================================================================

# Cowrie SSH Honeypot
COWRIE_SSH_PORT=2222
COWRIE_USER=cowrie

# Dionaea Multi-Protocol Honeypot
DIONAEA_HTTP_PORT=8080
DIONAEA_SMB_PORT=445
DIONAEA_MYSQL_PORT=3306

# OpenCanary Multi-service Honeypot (HTTP, FTP, Git, Redis)
OPENCANARY_HTTP_PORT=8081
OPENCANARY_FTP_PORT=2121
OPENCANARY_GIT_PORT=9418
OPENCANARY_REDIS_PORT=6379

# AI Model Engine
MODEL_PATH=/model/attack_classifier.pt

# Elasticsearch / ELK
ELASTIC_PORT=9200
LOGSTASH_PORT=5044
KIBANA_PORT=5601
ELASTIC_PASSWORD=changeme

# Threat Intel
THREAT_FEED_UPDATE_INTERVAL=86400
