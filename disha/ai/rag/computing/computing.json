        {"name": "Rust", "paradigm": "multi-paradigm", "typing": "static, strong", "year": 2015, "feature": "ownership system"},
        {"name": "C/C++", "paradigm": "imperative/OOP", "typing": "static, weak", "year": 1972},
        {"name": "Haskell", "paradigm": "purely functional", "typing": "static, strong", "year": 1990},
        {"name": "Go", "paradigm": "imperative/concurrent", "typing": "static, strong", "year": 2009},
