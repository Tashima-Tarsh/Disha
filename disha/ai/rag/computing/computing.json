{
  "domain": "Computing & Computer Science",
  "description": "Theory of computation, algorithms, programming, AI, and systems",
  "branches": [
    {
      "id": "theory_of_computation",
      "name": "Theory of Computation",
      "models": [
        {"name": "Turing Machine", "description": "Universal model of computation with infinite tape", "year": 1936},
        {"name": "Lambda Calculus", "description": "Formal system for function abstraction/application", "year": 1936},
        {"name": "Finite Automata", "description": "DFA/NFA for regular languages"},
        {"name": "Pushdown Automata", "description": "Automata with stack for context-free languages"},
        {"name": "Cellular Automata", "description": "Grid-based computation (Conway, Wolfram)"}
      ],
      "complexity_classes": ["P", "NP", "NP-complete", "NP-hard", "PSPACE", "EXPTIME", "BQP", "BPP"],
      "open_problems": ["P vs NP", "NP vs co-NP"],
      "key_theorems": ["Church-Turing thesis", "Rice's theorem", "Cook-Levin theorem (SAT is NP-complete)", "Halting problem undecidability"]
    },
    {
      "id": "algorithms",
      "name": "Algorithms & Data Structures",
      "sorting": [
        {"name": "QuickSort", "avg": "O(n log n)", "worst": "O(n²)", "space": "O(log n)"},
        {"name": "MergeSort", "avg": "O(n log n)", "worst": "O(n log n)", "space": "O(n)"},
        {"name": "HeapSort", "avg": "O(n log n)", "worst": "O(n log n)", "space": "O(1)"},
        {"name": "TimSort", "avg": "O(n log n)", "worst": "O(n log n)", "space": "O(n)"}
      ],
      "data_structures": [
        {"name": "Array", "access": "O(1)", "insert": "O(n)", "search": "O(n)"},
        {"name": "Hash Table", "access": "O(1) avg", "insert": "O(1) avg", "search": "O(1) avg"},
        {"name": "BST", "access": "O(log n)", "insert": "O(log n)", "search": "O(log n)"},
        {"name": "B-Tree", "access": "O(log n)", "insert": "O(log n)", "description": "Self-balancing tree for databases"},
        {"name": "Red-Black Tree", "access": "O(log n)", "insert": "O(log n)", "description": "Self-balancing BST"},
        {"name": "Trie", "insert": "O(m)", "search": "O(m)", "description": "Prefix tree for strings"},
        {"name": "Graph", "types": ["adjacency list", "adjacency matrix", "edge list"]}
