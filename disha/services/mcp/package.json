{
  "name": "disha-mcp",
  "version": "1.2.0",
  "mcpName": "io.github.tashima-tarsh/disha-mcp",
  "description": "MCP server for exploring the Disha AGI platform source code. STDIO, HTTP, and SSE transports.",
  "repository": {
    "type": "git",
    "url": "https://github.com/Tashima-Tarsh/Disha.git"
  },
  "author": "Tashima-Tarsh",
  "homepage": "https://github.com/Tashima-Tarsh/Disha#readme",
  "bugs": {
    "url": "https://github.com/Tashima-Tarsh/Disha/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "disha-mcp": "dist/index.js"
  },
  "scripts": {
